#!/bin/bash

# Pre-push hook — runs full lint before any push.

set -e

cd "$(git rev-parse --show-toplevel)"

echo "🔍 Pre-push lint..."

if ! make lint; then
    echo "❌ Lint failed. Fix the issues above before pushing."
    echo "💡 Run 'make lint' to see the full output."
    exit 1
fi

echo "✅ Pre-push checks passed."
