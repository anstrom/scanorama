#!/bin/bash

# Pre-commit hook — runs full lint before every commit.

set -e

cd "$(git rev-parse --show-toplevel)"

echo "🔍 Pre-commit checks..."

echo "  fmt..."
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ Unformatted files:"
    echo "$UNFORMATTED"
    echo "💡 Run 'make fmt' to fix."
    exit 1
fi

echo "  vet..."
if ! go vet ./...; then
    echo "❌ go vet failed. Fix the issues above before committing."
    exit 1
fi

echo "  lint..."
if ! make lint; then
    echo "❌ Lint failed. Fix the issues above before committing."
    echo "💡 Run 'make lint' to see the full output."
    exit 1
fi

echo "✅ Pre-commit checks passed."
