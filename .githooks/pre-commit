#!/bin/bash

# Source shell profile to ensure tools like go and golangci-lint are on PATH
# This is needed because git hooks run in a minimal environment
if [ -f "$HOME/.bash_profile" ]; then
    # shellcheck source=/dev/null
    source "$HOME/.bash_profile"
elif [ -f "$HOME/.profile" ]; then
    # shellcheck source=/dev/null
    source "$HOME/.profile"
fi
# Also source zshenv/zprofile for zsh users (common on macOS)
if [ -f "$HOME/.zshenv" ]; then
    # shellcheck source=/dev/null
    source "$HOME/.zshenv"
fi
if [ -f "$HOME/.zprofile" ]; then
    # shellcheck source=/dev/null
    source "$HOME/.zprofile"
fi

# Pre-commit hook to enforce code quality checks
# This hook runs before each commit and prevents commits if checks fail

set -e

echo "🔍 Running pre-commit checks..."

# Change to repository root
cd "$(git rev-parse --show-toplevel)"

# Run linting
echo "📝 Running linter..."
if ! make lint; then
    echo "❌ Linting failed! Please fix the issues above before committing."
    echo "💡 You can run 'make format' to automatically fix formatting issues."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
exit 0
